# Development image: installs all deps, runs tsx watch for hot reload.
FROM node:22-alpine

WORKDIR /app

# Install deps first for better layer caching.
COPY package*.json ./
RUN npm install

# Prisma schema is needed to generate the client.
COPY prisma ./prisma
RUN npx prisma generate

# Source is bind-mounted by docker-compose at runtime; copy as a fallback.
COPY . .

EXPOSE 4000
CMD ["npm", "run", "dev"]
