# Copy to .env (gitignored) for the Docker Compose workflow.
# Compose reads these to provision Postgres and configure the server/client.
# (For running the server locally with `npm run dev`, use server/.env instead,
#  with the DATABASE_URL host set to `localhost`.)

# --- Postgres (the `db` service) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Root@123
POSTGRES_DB=time_tracker_database

# --- Server ---
# Host is the compose service name `db`, NOT localhost.
# Special chars in the password must be URL-encoded: `@` -> %40.
DATABASE_URL=postgresql://postgres:Root%40123@db:5432/time_tracker_database
PORT=4000
NODE_ENV=development

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN_SECONDS=604800
OTP_TTL_MINUTES=10
# Allowed browser origin for CORS in production (unset = allow all in dev).
CLIENT_ORIGIN=

# --- Email (Resend) ---
# Leave blank to log OTPs to the console instead of emailing. Key from resend.com.
RESEND_API_KEY=
MAIL_FROM="Time Tracker <onboarding@resend.dev>"

# --- Client ---
# Base URL the browser uses to reach the API.
VITE_API_URL=http://localhost:4000
